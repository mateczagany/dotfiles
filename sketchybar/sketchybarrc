#!/usr/bin/env bash

PLUGIN_DIR="$CONFIG_DIR/plugins"
FONT_FAMILY="JetBrainsMono Nerd Font"
SPACE_APP_FONT="sketchybar-app-font:Regular:21.0"

export ACCENT_COLOR=0xff7dcfff
export ACTIVE_TEXT_COLOR=0xff1f2335
export ICON_COLOR=0xffc0caf5
export LABEL_COLOR=0xb3c0caf5
export DIM_COLOR=0x66c0caf5
export BRACKET_COLOR=0xcc272c40
export POPUP_COLOR=0xe61f2335

bar=(
  position=top
  height=48
  blur_radius=48
  color=0x00000000
  padding_left=6
  padding_right=6
  sticky=on
  topmost=off
)

default=(
  padding_left=9
  padding_right=9
  icon.font="$FONT_FAMILY:Regular:16.5"
  label.font="$FONT_FAMILY:Regular:16.5"
  icon.color="$ICON_COLOR"
  label.color="$LABEL_COLOR"
  icon.highlight_color="$ACCENT_COLOR"
  label.highlight_color="$ACCENT_COLOR"
  icon.padding_left=0
  icon.padding_right=0
  label.padding_left=0
  label.padding_right=0
  background.corner_radius=8
  background.height=33
  background.drawing=off
  scroll_texts=on
)

popup=(
  popup.align=right
  popup.blur_radius=48
  popup.background.color="$POPUP_COLOR"
  popup.background.corner_radius=12
  popup.background.border_color=0x00000000
  popup.background.border_width=0
)

bracket=(
  background.color="$BRACKET_COLOR"
  background.corner_radius=9
  background.height=42
)

space_defaults=(
  background.color="$ACCENT_COLOR"
  background.corner_radius=6
  background.height=27
  icon.font="$FONT_FAMILY:Bold:18.0"
  icon.padding_left=12
  icon.padding_right=12
  label.font="$SPACE_APP_FONT"
  label.padding_left=0
  label.padding_right=12
  padding_left=0
  padding_right=0
)

sketchybar --bar "${bar[@]}" --default "${default[@]}"

sketchybar --add item date right \
           --set date \
                 icon.drawing=off \
                 padding_left=0 \
                 padding_right=0 \
                 label.font="$FONT_FAMILY:Semibold:13.5" \
                 label.padding_left=0 \
                 label.padding_right=4 \
                 y_offset=0 \
                 update_freq=60 \
                 script="$PLUGIN_DIR/date.sh" \
                 click_script="open -a Calendar.app" \
           --add item clock right \
           --set clock \
                 icon.drawing=off \
                 padding_left=0 \
                 padding_right=0 \
                 label.font="$FONT_FAMILY:Bold:13.5" \
                 label.padding_left=6 \
                 label.padding_right=6 \
                 y_offset=0 \
                 update_freq=10 \
                 script="$PLUGIN_DIR/clock.sh" \
                 click_script="open -a Calendar.app" \
           --add item wifi right \
           --set wifi \
                  "${popup[@]}" \
                  update_freq=60 \
                  icon=󰤨 \
                  icon.font="$FONT_FAMILY:Regular:21.0" \
                  padding_left=3 \
                  padding_right=3 \
                  icon.padding_left=2 \
                  icon.padding_right=2 \
                  label.drawing=off \
                  script="$PLUGIN_DIR/wifi.sh" \
                  click_script="$PLUGIN_DIR/wifi.sh toggle" \
                  label.max_chars=24 \
           --subscribe wifi system_woke mouse.exited.global front_app_switched space_change display_change \
           --add item bluetooth right \
           --set bluetooth \
                  "${popup[@]}" \
                  update_freq=10 \
                  icon=󰂯 \
                  icon.font="$FONT_FAMILY:Regular:21.0" \
                  padding_left=3 \
                  padding_right=3 \
                  icon.padding_left=2 \
                  icon.padding_right=2 \
                  label.drawing=off \
                  script="$PLUGIN_DIR/bluetooth.sh" \
                  click_script="$PLUGIN_DIR/bluetooth.sh toggle" \
                  label.max_chars=40 \
           --subscribe bluetooth system_woke mouse.exited.global front_app_switched space_change display_change \
           --add item volume right \
           --set volume \
                  icon.font="$FONT_FAMILY:Regular:21.0" \
                  label.font="$FONT_FAMILY:Semibold:13.5" \
                  padding_left=3 \
                  padding_right=3 \
                  icon.padding_left=2 \
                  icon.padding_right=2 \
                  label.drawing=on \
                  script="$PLUGIN_DIR/volume.sh" \
           --subscribe volume volume_change \
           --add item battery right \
           --set battery \
                  icon.font="$FONT_FAMILY:Regular:21.0" \
                  label.font="$FONT_FAMILY:Semibold:13.5" \
                  padding_left=3 \
                  padding_right=3 \
                  icon.padding_left=2 \
                  icon.padding_right=2 \
                  label.drawing=on \
                  update_freq=120 \
                  script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change

sketchybar --add event aerospace_workspace_change

for sid in $(aerospace list-workspaces --all); do
  sketchybar --add item space.$sid left \
             --subscribe space.$sid aerospace_workspace_change front_app_switched \
             --set space.$sid \
                   "${space_defaults[@]}" \
                   update_freq=10 \
                   icon="$sid" \
                   label.drawing=off \
                   click_script="aerospace workspace $sid" \
                   script="$PLUGIN_DIR/aerospace.sh $sid"
done

sketchybar --add bracket spaces_cluster '/space\..*/' \
           --set spaces_cluster "${bracket[@]}" \
           --add bracket status_cluster date clock wifi bluetooth volume battery \
           --set status_cluster "${bracket[@]}" \
                padding_left=6 \
                padding_right=6

sketchybar --update
